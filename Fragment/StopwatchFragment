package com.example.alarm.Fragment;

import android.os.Bundle;
import android.os.Handler;
import android.os.Looper;
import android.os.SystemClock;
import android.view.View;
import android.widget.Button;
import android.widget.TextView;

import androidx.annotation.NonNull;
import androidx.annotation.Nullable;
import androidx.fragment.app.Fragment;

import com.example.alarm.R;

import java.util.Locale;

public class StopwatchFragment extends Fragment {

    private static final long UPDATE_INTERVAL_MS = 33;

    private TextView tvStopwatch;
    private Button btnStartPause;
    private Button btnReset;

    private Handler uiHandler;

    private boolean running = false;

    /*
     * accumulatedMillis: tổng thời gian của các lần chạy trước (khi pause).
     * startRealtime: mốc elapsedRealtime của lần Start gần nhất.
     */
    private long accumulatedMillis = 0;
    private long startRealtime = 0;

    private final Runnable updateRunnable = new Runnable() {
        @Override
        public void run() {
            updateDisplay();

            if (running && uiHandler != null) {
                uiHandler.postDelayed(this, UPDATE_INTERVAL_MS);
            }
        }
    };

    public StopwatchFragment() {
        super(R.layout.fragment_stopwatch);
    }

    @Override
    public void onViewCreated(
            @NonNull View view,
            @Nullable Bundle savedInstanceState
    ) {
        super.onViewCreated(view, savedInstanceState);

        tvStopwatch = view.findViewById(R.id.tv_stopwatch);
        btnStartPause = view.findViewById(R.id.btn_start_pause);
        btnReset = view.findViewById(R.id.btn_reset);

        uiHandler = new Handler(Looper.getMainLooper());

        btnStartPause.setOnClickListener(v -> {
            if (running) {
                pause();
            } else {
                start();
            }
        });

        btnReset.setOnClickListener(v -> reset());

        updateDisplay();
    }

    private void start() {
        running = true;
        startRealtime = SystemClock.elapsedRealtime();

        btnStartPause.setText("Pause");

        uiHandler.removeCallbacks(updateRunnable);
        uiHandler.post(updateRunnable);
    }

    private void pause() {
        accumulatedMillis += SystemClock.elapsedRealtime() - startRealtime;
        running = false;

        btnStartPause.setText("Start");

        uiHandler.removeCallbacks(updateRunnable);
        updateDisplay();
    }

    private void reset() {
        running = false;
        accumulatedMillis = 0;
        startRealtime = 0;

        btnStartPause.setText("Start");

        uiHandler.removeCallbacks(updateRunnable);
        updateDisplay();
    }

    private void updateDisplay() {
        if (tvStopwatch == null) {
            return;
        }

        long elapsed = accumulatedMillis;

        if (running) {
            elapsed += SystemClock.elapsedRealtime() - startRealtime;
        }

        long minutes = elapsed / 60_000;
        long seconds = (elapsed % 60_000) / 1000;
        long centis = (elapsed % 1000) / 10;

        tvStopwatch.setText(
                String.format(
                        Locale.getDefault(),
                        "%02d:%02d.%02d",
                        minutes,
                        seconds,
                        centis
                )
        );
    }

    @Override
    public void onDestroyView() {
        super.onDestroyView();

        if (uiHandler != null) {
            uiHandler.removeCallbacks(updateRunnable);
            uiHandler = null;
        }

        tvStopwatch = null;
        btnStartPause = null;
        btnReset = null;
    }
}

package com.example.alarm.Activities;

import android.content.Intent;
import android.os.Build;
import android.os.Bundle;
import android.view.WindowManager;
import android.widget.Button;
import android.widget.TextView;

import androidx.appcompat.app.AppCompatActivity;

import com.example.alarm.R;
import com.example.alarm.Service.AlarmService;
import com.example.alarm.Util.Constants;

/**
 * Màn hình hiển thị khi báo thức reo.
 * Được mở qua full screen notification từ AlarmService,
 * hiện được cả trên màn hình khóa.
 */
public class AlarmRingActivity extends AppCompatActivity {

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);

        showOverLockScreen();

        setContentView(R.layout.activity_alarm_ring);

        TextView tvTime = findViewById(R.id.tv_ring_time);
        TextView tvLabel = findViewById(R.id.tv_ring_label);
        Button btnSnooze = findViewById(R.id.btn_ring_snooze);
        Button btnDismiss = findViewById(R.id.btn_ring_dismiss);

        Intent intent = getIntent();

        String time = intent.getStringExtra(
                Constants.EXTRA_ALARM_TIME);
        String label = intent.getStringExtra(
                Constants.EXTRA_ALARM_LABEL);

        if (time != null) {
            tvTime.setText(time);
        }

        if (label != null) {
            tvLabel.setText(label);
        }

        btnSnooze.setOnClickListener(view -> {
            sendActionToService(Constants.ACTION_ALARM_SNOOZE);
            finish();
        });

        btnDismiss.setOnClickListener(view -> {
            sendActionToService(Constants.ACTION_ALARM_DISMISS);
            finish();
        });
    }

    private void showOverLockScreen() {
        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O_MR1) {
            setShowWhenLocked(true);
            setTurnScreenOn(true);
        } else {
            getWindow().addFlags(
                    WindowManager.LayoutParams.FLAG_SHOW_WHEN_LOCKED
                            | WindowManager.LayoutParams.FLAG_TURN_SCREEN_ON
            );
        }

        getWindow().addFlags(
                WindowManager.LayoutParams.FLAG_KEEP_SCREEN_ON
        );
    }

    private void sendActionToService(String action) {
        Intent serviceIntent = new Intent(this, AlarmService.class);
        serviceIntent.setAction(action);
        startService(serviceIntent);
    }

    /*
     * Không cho bấm Back để né báo thức.
     */
    @Override
    public void onBackPressed() {
        // Bỏ qua
    }
}

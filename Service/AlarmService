package com.example.alarm.Service;

import android.app.Service;
import android.content.Intent;
import android.net.Uri;
import android.os.Build;
import android.os.Handler;
import android.os.IBinder;
import android.os.Looper;
import android.os.VibrationEffect;
import android.os.Vibrator;

import androidx.annotation.Nullable;

import com.example.alarm.DAO.AlarmDao;
import com.example.alarm.Model.Alarm;
import com.example.alarm.Util.AlarmScheduler;
import com.example.alarm.Util.Constants;
import com.example.alarm.Util.MusicHelper;
import com.example.alarm.Util.NotificationHelper;

/**
 * Foreground service chạy khi báo thức reo.
 *
 * Nhiệm vụ:
 *  - Phát nhạc (URI người dùng chọn / random / mặc định)
 *  - Áp dụng volume, loop, vibrate
 *  - Hiện notification full screen (mở AlarmRingActivity)
 *  - Xử lý Snooze / Dismiss
 *  - Đặt lịch lần reo kế tiếp cho alarm lặp lại
 */
public class AlarmService extends Service {

    private MusicHelper musicHelper;
    private Vibrator vibrator;
    private Handler timeoutHandler;

    private int currentAlarmId = Constants.INVALID_ALARM_ID;

    @Override
    public void onCreate() {
        super.onCreate();

        musicHelper = new MusicHelper();
        vibrator = (Vibrator) getSystemService(VIBRATOR_SERVICE);
        timeoutHandler = new Handler(Looper.getMainLooper());
    }

    @Override
    public int onStartCommand(Intent intent, int flags, int startId) {
        if (intent == null || intent.getAction() == null) {
            stopSelf();
            return START_NOT_STICKY;
        }

        String action = intent.getAction();

        switch (action) {
            case Constants.ACTION_ALARM_TRIGGER:
                handleAlarmTrigger(intent);
                break;

            case Constants.ACTION_ALARM_SNOOZE:
                handleSnooze();
                break;

            case Constants.ACTION_ALARM_DISMISS:
                stopAlarm();
                break;

            default:
                stopSelf();
                break;
        }

        return START_NOT_STICKY;
    }

    private void handleAlarmTrigger(Intent intent) {
        int alarmId = intent.getIntExtra(
                Constants.EXTRA_ALARM_ID,
                Constants.INVALID_ALARM_ID
        );

        if (alarmId == Constants.INVALID_ALARM_ID) {
            stopSelf();
            return;
        }

        AlarmDao alarmDao = new AlarmDao(this);
        Alarm alarm = alarmDao.getAlarmbyId(alarmId);

        if (alarm == null) {
            stopSelf();
            return;
        }

        currentAlarmId = alarmId;

        NotificationHelper.createNotificationChannel(this);

        startForeground(
                Constants.ALARM_NOTIFICATION_ID,
                NotificationHelper.buildAlarmNotification(this, alarm)
        );

        playAlarmSound(alarm);

        if (alarm.getVibrate()) {
            startVibration();
        }

        /*
         * Alarm lặp: đặt lịch cho ngày kế tiếp.
         * Alarm một lần: tắt trong database sau khi reo.
         */
        if (AlarmScheduler.isRepeating(alarm)) {
            AlarmScheduler.schedule(this, alarm);
        } else {
            alarm.setEnabled(false);
            alarmDao.updateAlarm(alarm);
        }

        // Tự tắt nếu người dùng không tương tác
        timeoutHandler.removeCallbacksAndMessages(null);
        timeoutHandler.postDelayed(
                this::stopAlarm,
                Constants.ALARM_AUTO_STOP_MS
        );
    }

    private void playAlarmSound(Alarm alarm) {
        /*
         * Báo thức phải reo đến khi người dùng tắt,
         * nên bỏ auto-stop 20 giây của MusicHelper.
         */
        musicHelper.setAutoStop(false);

        String musicUri = alarm.getMusicUri();

        if (alarm.getRandomMusic()) {
            musicHelper.playRandom(this);
        } else if (musicUri != null && !musicUri.trim().isEmpty()) {
            musicHelper.playFromUri(this, Uri.parse(musicUri));
        } else {
            musicHelper.playDefault(this);
        }

        musicHelper.setLooping(alarm.getLoop());
        musicHelper.setVolume(alarm.getVolumne() / 100f);
    }

    private void startVibration() {
        if (vibrator == null || !vibrator.hasVibrator()) {
            return;
        }

        long[] pattern = {0, 800, 800};

        if (Build.VERSION.SDK_INT >= Build.VERSION_CODES.O) {
            vibrator.vibrate(
                    VibrationEffect.createWaveform(pattern, 0)
            );
        } else {
            vibrator.vibrate(pattern, 0);
        }
    }

    private void handleSnooze() {
        if (currentAlarmId != Constants.INVALID_ALARM_ID) {
            AlarmScheduler.scheduleSnooze(
                    this,
                    currentAlarmId,
                    Constants.DEFAULT_SNOOZE_MINUTES
            );
        }

        stopAlarm();
    }

    private void stopAlarm() {
        timeoutHandler.removeCallbacksAndMessages(null);

        musicHelper.stop();

        if (vibrator != null) {
            vibrator.cancel();
        }

        currentAlarmId = Constants.INVALID_ALARM_ID;

        stopForeground(true);
        stopSelf();
    }

    @Override
    public void onDestroy() {
        timeoutHandler.removeCallbacksAndMessages(null);

        musicHelper.release();

        if (vibrator != null) {
            vibrator.cancel();
        }

        super.onDestroy();
    }

    @Nullable
    @Override
    public IBinder onBind(Intent intent) {
        return null;
    }
}

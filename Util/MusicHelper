package com.example.alarm.Util;

import android.content.Context;
import android.media.AudioAttributes;
import android.media.MediaPlayer;
import android.net.Uri;
import android.os.Handler;
import android.os.Looper;
import com.example.alarm.R;
import java.util.Random;

public class MusicHelper {
    private MediaPlayer mediaPlayer;
    private Handler handler;
    private Runnable stopRunnable;
    private final long MAX_PLAY_DURATION = 20000;

    /*
     * true: tự dừng sau MAX_PLAY_DURATION (dùng cho preview / timer).
     * false: phát đến khi gọi stop() (dùng cho báo thức).
     */
    private boolean autoStop = true;
    private static final int[] DEFAULT_ALARMS = {
          R.raw.alarm1,
          R.raw.alarm2,
          R.raw.alarm3,
            R.raw.alarm4,
            R.raw.alarm5

    };
    public MusicHelper(){
        handler = new Handler(Looper.getMainLooper());
        stopRunnable = () -> stop();
    }

    public void playFromResource(Context context, int resId){
        stop();
        mediaPlayer = MediaPlayer.create(context,resId);
        if(mediaPlayer!=null){
            mediaPlayer.start();
            startTimer();
        }
    }
    public void playDefault(Context context){
        playFromResource(context,DEFAULT_ALARMS[0]);
    }
    public void playFromUri(Context context, Uri uri){
        stop();
        try {
            mediaPlayer = new MediaPlayer();
            mediaPlayer.setAudioAttributes(
                    new AudioAttributes.Builder()
                            .setUsage(AudioAttributes.USAGE_ALARM)
                            .setContentType(AudioAttributes.CONTENT_TYPE_MUSIC)
                            .build()
            );
            mediaPlayer.setDataSource(context, uri);
            mediaPlayer.prepare();
            mediaPlayer.start();
            startTimer();
        } catch (Exception e) {
            // File không đọc được (bị xóa, mất quyền...) thì phát nhạc mặc định
            if (mediaPlayer != null) {
                mediaPlayer.release();
                mediaPlayer = null;
            }
            playDefault(context);
        }
    }
    public void setAutoStop(boolean autoStop){
        this.autoStop = autoStop;
        if (!autoStop) {
            cancelTimer();
        }
    }
    public void playRandom(Context context){
        Random random = new Random();
        int index = random.nextInt(DEFAULT_ALARMS.length);
        playFromResource(context,DEFAULT_ALARMS[index]);
    }
    public void pause(){
        if(mediaPlayer != null && mediaPlayer.isPlaying()){
            mediaPlayer.pause();
            cancelTimer();
        }
    }
    public void resume(){
        if(mediaPlayer!=null){
            mediaPlayer.start();
            startTimer();
        }
    }
    public void stop(){
        cancelTimer();
        if(mediaPlayer != null){
            if(mediaPlayer.isPlaying()){
                mediaPlayer.stop();
            }
            mediaPlayer.release();
            mediaPlayer = null;
        }
    }
    public void release(){
        cancelTimer();
        if(mediaPlayer != null){
            mediaPlayer.release();
            mediaPlayer = null;
        }
    }
    public void setLooping(boolean looping){
        if(mediaPlayer != null) {
            mediaPlayer.setLooping(looping);
        }
    }
    public void setVolume(float volume){
        if(mediaPlayer != null){
            volume = Math.max(0f,Math.min(volume,1f));
            mediaPlayer.setVolume(volume,volume);
        }
    }
    public boolean isPlaying(){
        return mediaPlayer != null && mediaPlayer.isPlaying();
    }
    private void startTimer(){
        cancelTimer();
        if(autoStop && handler != null && stopRunnable != null){
            handler.postDelayed(stopRunnable,MAX_PLAY_DURATION);
        }
    }
    private void cancelTimer(){
        if(handler != null && stopRunnable != null){
            handler.removeCallbacks(stopRunnable);
        }
    }

}
